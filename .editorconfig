###############################################################################
# CHIP-8 Emulator
#
# Editor configuration
#
# This file defines the basic formatting rules for all source files in the
# project. Most modern IDEs and editors support EditorConfig natively.
###############################################################################

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.ui]
indent_size = 2

[*.qrc]
indent_size = 2

[*.xml]
indent_size = 2

[*.cmake]
indent_size = 4

[CMakeLists.txt]
indent_size = 4
